  /* Reset some default spacing */
body {
    font-family: serif;
    background: linear-gradient(to right, #74ebd5, #ACB6E5);
    margin: 0;
    padding: 0;
}

/* Main container style */
form {
    background: white;
    width: 400px;
    margin: 30px auto;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 0 15px rgba(0,0,0,0.2);
}

/* Headings */
h1 {
    text-align: center;
    color: #333;
}

h2 {
    color: #555;
}

/* Labels */
label {
    font-weight: bold;
}

/* Inputs, select, textarea */
input, select, textarea {
    width: 100%;
    padding: 8px;
    margin-top: 5px;
    border-radius: 5px;
    border: 1px solid #ccc;
}

/* Focus effect */
input:focus, textarea:focus, select:focus {
    border-color: #007BFF;
    outline: none;
}

/* Buttons */
button {
    padding: 10px;
    margin-top: 10px;
    width: 48%;
    border: none;
    border-radius: 5px;
    cursor: pointer;
}

/* Submit button */
button[type="submit"] {
    background-color: #28a745;
    color: white;
}

/* Reset button */
button[type="reset"] {
    background-color: #dc3545;
    color: white;
}

/* Button hover */
button:hover {
    opacity: 0.9;
}

/* Spacing between sections */
hr {
    margin: 20px 0;
}
