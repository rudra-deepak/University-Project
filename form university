    <div class="container">
   
    <h1 id="topic">University Registration Form</h1>
    <br><br>
    <P style="font-size: 18px; font-weight: bold; color: #060000;">
         If you have already registered, please click here.</P>
         <!-- <a href="login.html" >login</a>  -->
        <button type="login" style="height: 35px; width: 50px; color: #ce0808; border-color: rgb(249, 141, 0); ">login</button>
        <br><br>
<p id="line1"> <span class="way">Please fill out the form below to register:</span></p>
<form>
    <hr>

    <h2 class="sub-title">Personal Details
    </h2><br><br>
        <label for="FirstName" ID="FIRSTNAME1"
        class="info">First Name:</label>
        <input type="text"  name="FirstName" id="FirstName" placeholder="Enter your first name" required>
        <br><br>

      <label for="LastName" class="info" ID="LASTNAME1">last Name:</label>
        <input type="text"  name="LastName" id="LastName" placeholder="Enter your last name" required>
        <br><br>

        <label for="dateofbirth" class="info" ID="DATEOFBIRTH1">Date of Birth:</label>
        <input type="date"  name="dateofbirth" id="dateofbirth"  >
        <br><br>

        <p><h3 class="sub-title">Gender:</h3></p>
        <label for="male" class="info">  male:</label>
        <input type="radio"  name="gender" id="male" required >
        <br>
         <label for="female" class="info">female:</label>
        <input type="radio"  name="gender" id="female"  required >
        <br>
        <label for="other" class="info">other:</label>
        <input type="radio"  name="gender" id="other"    required >
        <br><br>

        <p ><h2 class="sub-title">Upload your photo:</h2></p>
        <input type="file" name="photo" id="photo" >

        <hr>
        <h2 class="sub-title">Contact Information</h2> <br><br>
        <label for="email" class="info">Email:</label>
        <input type="email" name="email" id="email" placeholder="Enter your email" required>
        <br><br>    
        <label for="phone" class="info">Phone Number:</label>
        <input type="tel" name="phone" id="phone" placeholder="Enter your phone number" required>
        <br><br>
        <label for="address" class="info">Mailing Address:</label>
        <textarea name="address" id="address" placeholder="Enter your mailing address"></textarea>
            <hr>
            <h2 class="sub-title">Academic Information</h2>
            <p class="info">select your course:</p>
        
        
            <select name="course" id="course" required  >
                <option value="CSE">CSE</option>
                <option value="ME">ME</option>
                <option value="CE">CE</option>
            
            </select> <br><br>

           <h3 class="sub-title">Extra-curricular Activity:</h3> <br>
            
           <label for="sports" class="info">Sports:</label>
           <input type="checkbox" name="sports" id="sports" >  <br>


             <label for="music and arts" class="info">Music and Arts:</label>
           <input type="checkbox" name="music and arts" id="musicarts" ><br>


            <label for="Technology Club" class="info">Technology Club:</label>
           <input type="checkbox" name="Technology Club" id="TechnologyClub" ><br>


            <label for="Volunteer" class="info">Volunteer:</label>
           <input type="checkbox" name="Volunteer" id="Volunteer" ><br>

        <hr>
        <h2 class="sub-title">Create your account</h2> <br><br>
        <label for="Create your password" class="info">Create your password:</label>
        <input type="password" name="password" id="password" placeholder="Choose a password" required>
        <br><br>    

        <label for="Security question" class="info">Security Question:</label>
        <select name="Security question" id="Securityquestion" required>
            <option value="What is your mother's maiden name?">What is your mother's maiden name?</option>
            <option value="What was the name of your first pet?">What was the name of your first pet?</option>
            <option value="What is your favorite book?">What is your favorite book?</option>
           </select>
        <br><br>
        <label for="Security answer" class="info">Security Answer:</label>
        <input type="text" name="Security answer" id="Security answer" placeholder="Enter your security answer" required    >
        <br><br>


<input type="checkbox" name="terms" id="terms" required>
<label for="terms">I agree to the terms and conditions:</label>
  <br><br>

 <hr>
 <button type="submit">Register</button>
 <button type="reset">Reset</button>
 
 </div>

</form >


